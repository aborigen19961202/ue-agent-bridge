{
  "name": "ue-agent-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Narrow M0 Unreal Engine agent bridge for external coding agents",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server/index.ts",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.4"
  }
}
